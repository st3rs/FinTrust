# ── docgen service environment ───────────────────────────────────────────────
# Copy to .env and fill in real values before running.
# Never commit .env to git.

# Port the docgen HTTP server listens on
PORT=8080

# Gotenberg container URL (internal Docker network when using docker-compose)
GOTENBERG_URL=http://localhost:3001

# Supabase project URL — same value as VITE_SUPABASE_URL in the frontend
SUPABASE_URL=https://your-project.supabase.co

# Service role key — bypasses RLS; server-side only, never expose to frontend
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Supabase Storage bucket name for generated PDFs
# Create this bucket in Supabase Dashboard → Storage before first run
SUPABASE_STORAGE_BUCKET=documents

# Signed-URL lifetime in seconds (optional; default 3600 = 1 hour).
# Clamped to [60, 604800] (1 min … 7 days). Lengthen for URLs emailed to
# clients — but never cache a signed URL; always re-mint via GET /v1/documents/:id.
DOCGEN_SIGNED_URL_TTL=3600

# Optional: extra Chromium wait before PDF capture (e.g. "1s"). Leave UNSET.
# The Thai font is baked into the Gotenberg image, so the default template needs
# no wait. Only set this if you add a template that loads remote assets.
# GOTENBERG_WAIT_DELAY=

# ── API key salt — READ THIS ─────────────────────────────────────────────────
# Salt for HMAC-SHA256 hashing of `ft_` API keys.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
#
# IMMUTABLE ONCE KEYS ARE ISSUED. Existing key hashes in the api_keys table are
# computed against THIS salt; changing it makes every issued key fail to
# validate (401) with no error explaining why. Treat it as permanent:
#   • Set it ONCE, store it in your secret manager, never rotate casually.
#   • It MUST be identical in this file AND the repo-root .env.
#   • Rotating it = re-issuing every API key. Plan a key-reissue flow first.
DOCGEN_API_KEYS_SALT=change-me-generate-a-random-32-byte-hex-string
